{
  "compilerOptions": {
  "target": "ES2020",
  "module": "commonjs",
  "lib": ["ES2020"],
  "strict": true,
  "ignoreDeprecations": "6.0",
  "esModuleInterop": true,
  "skipLibCheck": true,
  "forceConsistentCasingInFileNames": true,
  "outDir": "./dist",
  "rootDir": "./",
  "baseUrl": ".",
  "types": ["node"],
  "paths": {
    "@pages/*": ["pages/*"],
    "@utils/*": ["utils/*"]
  }
},

  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
